# =============================================================================
# ArmaField Linux Server configuration
# Copy this file to .env and edit values: cp .env.example .env
# DO NOT put quotes around values - docker compose env_file parses them literally.
# =============================================================================

# --- Public network ---
# Public IPv4 address of your server (what players see in the server browser).
# Leave blank only for LAN/local testing. Without this, Arma Reforger registers
# with the container's internal Docker IP and clients can't connect.
SERVER_PUBLIC_ADDRESS=

# --- Ports (must match your config.json values and be open in host firewall) ---
GAME_PORT=2001
A2S_PORT=17777
RCON_PORT=19999

# --- Server startup flags ---
# Edit to add/remove flags. Full list:
# https://community.bistudio.com/wiki/Arma_Reforger:Startup_Parameters
ARMA_PARAMS=-maxFPS 120 -backendlog -nothrow

# --- SteamCMD update strategy ---
# How often to re-check for game updates (minutes). 0 = every container start.
STEAMCMD_CHECK_INTERVAL_MINUTES=60

# Force-skip all update checks (for maintenance / debugging).
SKIP_INSTALL=false